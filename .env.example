# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_VECTOR_STORE_ID=          # ID del vector store del catálogo (lo creas en OpenAI y lo pegas aquí)
FILE_SEARCH_MAX_RESULTS=20       # fragmentos que file_search recupera por llamada (default 20 = playground). Ver ADR-0024
OPENAI_TRANSCRIBE_MODEL=whisper-1  # transcripción de notas de voz (default whisper-1). Ver ADR-0022
REPLY_DEBOUNCE_MS=12000          # espera para agrupar mensajes seguidos antes de responder (default 12s)

# ---- Comprensión de audio e imágenes (multimodal, ver docs/15, ADR-0022) ----
MEDIA_UNDERSTANDING_ENABLED=true # kill switch (default ON; "false"/"0" ignora el media)
MEDIA_MAX_BYTES=20971520         # límite de descarga de un adjunto (default 20 MB)

# ---- Retargeting (seguimientos automáticos, ver ADR-0017 / ADR-0052) ----
# Cada agente define sus etapas (cuántas y a qué hora) en /dashboard/retargets
# (agents.retarget_config). Estos delays son solo el BACKSTOP genérico: se usan
# cuando el agente no configuró etapas propias. La 3ª es ~23h (no 24h) a propósito:
# entra en la ventana de 24h de WhatsApp y sí se entrega.
RETARGET_ENABLED=true            # kill switch global (default ON; "false"/"0" lo apaga)
RETARGET_STAGE1_MS=3600000       # backstop 1ª etapa: ~1h (default 1h)
RETARGET_STAGE2_MS=28800000      # backstop 2ª etapa: ~8h (default 8h)
RETARGET_STAGE3_MS=82800000      # backstop 3ª etapa: ~23h (default 23h, near-24h)
CRON_SECRET=                     # protege /api/cron/retargets; Vercel lo manda como Bearer. Si vacío, abierto (dev)

# ---- Reactivaciones por plantilla (7/15 días, ver ADR-0021) ----
# El ON/OFF y los UUID de plantilla se editan desde el DASHBOARD (tabla app_settings), no aquí.
# Estas envs solo ajustan los delays de las dos etapas (útiles para pruebas).
REACTIVATION_STAGE1_MS=604800000   # 1ª etapa: 7 días desde el primer contacto (default 7d)
REACTIVATION_STAGE2_MS=1296000000  # 2ª etapa: 15 días desde el primer contacto (default 15d)

# ---- Callbell ----
CALLBELL_API_KEY=                # key GLOBAL (fallback). Por agente puede haber otra (tabla agents)
CALLBELL_WEBHOOK_SECRET=         # secret compartido para validar el webhook
# Multi-agente (ver docs/16, ADR-0023): enrutamiento y credenciales viven en la tabla `agents`
# (editable desde el dashboard). Estas 3 quedan como FALLBACK del agente seed (Vitasei CO) hasta
# pegar sus IDs en el dashboard; producción no se cae en la transición.
CALLBELL_LOGISTICS_TEAM_UUID=    # equipo de handoff (fallback del agente seed)
CALLBELL_WHATSAPP_CHANNEL_UUID=  # canal del número de la IA (fallback de enrutamiento + envío)
AGENT_WHATSAPP_NUMBER=573332877350  # número de la IA E.164 sin '+' (fallback de enrutamiento del seed)

# ---- Kapso (segundo proveedor de WhatsApp — ver docs/24, ADR-0056) ----
# TODO OPCIONAL. El proveedor y sus credenciales se configuran POR AGENTE desde el dashboard
# (`agents.provider` + `agents.kapso_*`), porque cada marca vive en su propio proyecto de Kapso.
# Estas envs son solo el FALLBACK mientras se pegan los IDs, igual que las de Callbell.
# Sin ningún agente en Kapso, nada de esto se usa y el backend se comporta como siempre.
KAPSO_API_KEY=                   # key del proyecto de Kapso (header X-API-Key)
KAPSO_PHONE_NUMBER_ID=           # Meta Phone Number ID del número (envío + enrutamiento del inbound)
KAPSO_WEBHOOK_SECRET=            # secret_key con el que se registró el webhook (firma HMAC SHA256)
KAPSO_TEMPLATE_LANGUAGE=es_CO    # idioma default de las plantillas (Kapso las pide por nombre + idioma)

# ---- Addi (v1: solo link/instrucciones, sin API) ----
ADDI_LINK=                       # link que se envía con #addi (opcional)

# ---- Aviso de venta al dueño (WhatsApp) ----
# E.164 sin '+'. Default 573103565492 en código; vacío = apagado. Mensaje libre:
# WhatsApp solo lo entrega dentro de la ventana de 24h de este número (ver docs).
SALES_NOTIFY_PHONE=573103565492

# ---- Supabase (proyecto: seller-agent-vitasei) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=       # SOLO server

# ---- Admin ----
CATALOG_ADMIN_SECRET=            # protege POST /api/catalog/load (si vacío, abierto en dev)

# ---- Hotmart (carritos abandonados, ver docs/17, ADR-0035/0040) ----
HOTMART_WEBHOOK_SECRET=                   # secret para validar el webhook de Hotmart (si vacío, abierto en dev)
HOTMART_ABANDONED_CART_TEMPLATE_UUID=     # FALLBACK: la plantilla y el texto se editan en el dashboard (/dashboard/hotmart); esta env solo se usa si no hay plantilla ahí (ADR-0040)
HOTMART_AGENT_ID=                         # FALLBACK: el agente de Hotmart se designa en el dashboard (/dashboard/hotmart, agents.hotmart_enabled); esta env solo aplica si no hay ninguno marcado (ADR-0041)

# ---- Dashboard (Basic Auth) ----
DASHBOARD_USER=admin             # usuario del panel (default admin)
DASHBOARD_PASSWORD=              # si vacío, el panel queda ABIERTO. Ponlo en producción.

# --- Llamadas con IA (Synthflow) — docs/25, ADR-0060..0063 -------------------
# Kill switch global. OFF por defecto: un fallo aquí llama a un cliente real.
# Prender exige además `agents.voice_enabled` en el dashboard.
VOICE_CALLS_ENABLED=false
# API key global (cada agente puede sobreescribirla en el dashboard).
SYNTHFLOW_API_KEY=
# Base REGIONAL del workspace. OJO: con la misma key, la región equivocada
# devuelve 401 (no 404). Opciones: api / api.us / api.eu .synthflow.ai
SYNTHFLOW_API_BASE=https://api.synthflow.ai/v2
# Requerido SOLO para listar voces. Es DISTINTO de la API key.
SYNTHFLOW_WORKSPACE_ID=
# Secreto del post-call webhook (Admin > Workspace Settings > Security > Webhooks).
SYNTHFLOW_WEBHOOK_SECRET=
# Costo estimado por minuto: Synthflow no expone costo por API. Rango 0.15-0.24.
SYNTHFLOW_USD_PER_MINUTE=0.20

# --- Gasto real en pauta (API para el producto de anuncios) — docs/28, ADR-0082 ---
# Token Bearer que usa Roberto para mandar el gasto diario a POST /api/ingest/ad-spend.
# Si está VACÍO el endpoint responde 503 (cerrado), no abierto: es escritura pública.
# Generar con: openssl rand -hex 32
AD_SPEND_API_KEY=
